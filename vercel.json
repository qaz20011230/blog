{
  "headers": [
    {
      "source": "/cv",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"Ang_Li_CV.pdf\""
        }
      ]
    },
    {
      "source": "/cv_Ang.pdf",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"Ang_Li_CV.pdf\""
        }
      ]
    },
    {
      "source": "/resume",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"LiAng_Resume.pdf\""
        }
      ]
    },
    {
      "source": "/LiAng_Resume.pdf",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"LiAng_Resume.pdf\""
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(.*)\\.vercel\\.app"
        }
      ],
      "destination": "https://liang.world/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/cv",
      "destination": "/cv_Ang.pdf"
    },
    {
      "source": "/resume",
      "destination": "/LiAng_Resume.pdf"
    },
    {
      "source": "/en/sitemap.xml",
      "destination": "/en-sitemap.xml"
    },
    {
      "source": "/en/rss.xml",
      "destination": "/en-rss.xml"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
